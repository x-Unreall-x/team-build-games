---
import { ARCADE_GAMES } from "../../lib/games/registry";

const ART: Record<string, { image: string; width: number; height: number; alt: string }> = {
  arena: {
    image: "/assets/arena/arena-screenshot.png",
    width: 834,
    height: 640,
    alt: "Arena gameplay with two warriors facing off on a battlefield",
  },
  overrun: {
    image: "/assets/overrun/overrun-screenshot.png",
    width: 1586,
    height: 992,
    alt: "Two Overrun players firing at a rock tank and two rushing monsters",
  },
  squid: {
    image: "/assets/squid/squid-screenshot.png",
    width: 1200,
    height: 803,
    alt: "A purple squid walking toward the finish arch with its eight legs",
  },
  "road-madness": {
    image: "/assets/road-madness/road-madness-screenshot.webp",
    width: 1536,
    height: 1024,
    alt: "Road Madness demolition cars drifting in a neon derby pit",
  },
};

const THEME: Record<string, { accent: string; border: string; glow: string; play: string }> = {
  arena: {
    accent: "text-cyan-300",
    border: "border-cyan-400/45",
    glow: "shadow-[0_0_46px_rgb(34_211_238/0.28)]",
    play: "bg-cyan-400 border-cyan-200 shadow-[0_0_28px_rgb(34_211_238/0.5)]",
  },
  overrun: {
    accent: "text-red-300",
    border: "border-red-400/45",
    glow: "shadow-[0_0_46px_rgb(248_113_113/0.24)]",
    play: "bg-red-400 border-red-200 shadow-[0_0_28px_rgb(248_113_113/0.48)]",
  },
  squid: {
    accent: "text-violet-300",
    border: "border-violet-400/45",
    glow: "shadow-[0_0_46px_rgb(167_139_250/0.24)]",
    play: "bg-violet-400 border-violet-200 shadow-[0_0_28px_rgb(167_139_250/0.48)]",
  },
  "road-madness": {
    accent: "text-amber-200",
    border: "border-amber-300/45",
    glow: "shadow-[0_0_46px_rgb(251_191_36/0.22)]",
    play: "bg-amber-300 border-amber-100 shadow-[0_0_28px_rgb(251_191_36/0.45)]",
  },
};

const games = ARCADE_GAMES
  .filter((game) => game.status === "live" && ART[game.slug])
  .map((game) => ({
    ...game,
    ...ART[game.slug],
    theme: THEME[game.slug] ?? THEME.arena,
  }));
---

<div
  id="hero-game-picker"
  class="hero-game-picker relative mx-auto w-full max-w-[42rem]"
  data-hero-game-picker
  aria-label="Arcade game picker"
>
  <div class="mb-3 flex items-center justify-between gap-3">
    <div>
      <p class="eyebrow text-fuchsia-400">Choose cabinet</p>
      <h2 class="mt-1 font-display text-base text-white">Pick a game, hit play</h2>
    </div>
    <div class="hidden items-center gap-2 font-display text-[8px] text-neutral-500 sm:flex">
      <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_rgb(52_211_153/0.9)]"></span>
      Live games
    </div>
  </div>

  <div class="hero-picker-stage pixel-grid relative overflow-hidden rounded-[1.6rem] border border-white/10 bg-night-950/70 px-10 py-6 sm:px-14 sm:py-8">
    <div class="hero-picker-scanlines pointer-events-none absolute inset-0 z-40" aria-hidden="true"></div>

    <button
      type="button"
      class="hero-picker-arrow hero-picker-arrow--left"
      data-hero-picker-prev
      aria-label="Previous game"
    >
      ‹
    </button>
    <button
      type="button"
      class="hero-picker-arrow hero-picker-arrow--right"
      data-hero-picker-next
      aria-label="Next game"
    >
      ›
    </button>

    <div class="relative mx-auto aspect-[4/3] w-full max-w-[31rem] sm:aspect-[16/10]">
      {
        games.map((game, index) => (
          <article
            class={`hero-picker-card absolute inset-0 rounded-2xl border bg-night-900 p-2 ${game.theme.border} ${game.theme.glow}`}
            data-hero-picker-card
            data-picker-index={index}
            data-picker-position={index === 0 ? "active" : index === 1 ? "right" : index === games.length - 1 ? "left" : "hidden"}
            aria-label={`${game.name} game preview`}
          >
            <div class="relative h-full overflow-hidden rounded-xl bg-night-950">
              <img
                src={game.image}
                alt={game.alt}
                class="absolute inset-0 h-full w-full object-cover object-center"
                width={game.width}
                height={game.height}
                loading={index === 0 ? "eager" : "lazy"}
                fetchpriority={index === 0 ? "high" : "auto"}
              />
              <div
                class="absolute inset-0 bg-[linear-gradient(to_bottom,rgb(6_6_16/0.04)_0%,transparent_34%,rgb(6_6_16/0.96)_100%)]"
                aria-hidden="true"
              ></div>
              <div class="absolute inset-x-0 top-0 flex items-center justify-between p-4">
                <span class={`rounded border bg-night-950/85 px-3 py-2 font-display text-[8px] backdrop-blur-sm ${game.theme.border} ${game.theme.accent}`}>
                  {game.kind}
                </span>
                <span class="rounded border border-white/15 bg-night-950/85 px-3 py-2 font-display text-[8px] text-neutral-200 backdrop-blur-sm">
                  {game.players}
                </span>
              </div>

              <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6">
                <p class={`eyebrow ${game.theme.accent}`}>Selected game</p>
                <div class="mt-2 flex items-end justify-between gap-4">
                  <div class="min-w-0">
                    <h3 class="font-display text-2xl text-white sm:text-3xl">{game.name}</h3>
                    <p class="mt-2 line-clamp-2 max-w-sm text-sm leading-relaxed text-neutral-300">
                      {game.blurb}
                    </p>
                  </div>
                  <a
                    href={game.href}
                    class={`hero-picker-play relative z-50 flex shrink-0 items-center justify-center rounded border-2 px-4 py-3 text-center font-display text-[8px] leading-tight text-night-950 transition hover:scale-105 sm:px-5 sm:py-4 sm:text-[9px] ${game.theme.play}`}
                    aria-label={`Play ${game.name}`}
                  >
                    Press<br />to Play
                  </a>
                </div>
              </div>
            </div>

            <button
              type="button"
              class="hero-picker-card-hit absolute inset-0 z-30 rounded-2xl"
              data-hero-picker-card-hit
              aria-label={`Select ${game.name}`}
            ></button>
          </article>
        ))
      }
    </div>

    <div class="mt-5 flex items-center justify-center gap-2" aria-label="Game picker position">
      {
        games.map((game, index) => (
          <button
            type="button"
            class="hero-picker-dot"
            data-hero-picker-dot
            data-picker-index={index}
            aria-label={`Select ${game.name}`}
            aria-current={index === 0 ? "true" : "false"}
          ></button>
        ))
      }
    </div>
  </div>

  <p class="mt-3 text-center font-display text-[8px] tracking-wide text-neutral-500">
    Use ← / → arrows or tap the side cabinets
  </p>
</div>

<script>
  function wireHeroGamePickers() {
    document.querySelectorAll<HTMLElement>("[data-hero-game-picker]").forEach((picker) => {
      if (picker.dataset.wired === "1") return;
      picker.dataset.wired = "1";

      const cards = Array.from(picker.querySelectorAll<HTMLElement>("[data-hero-picker-card]"));
      const dots = Array.from(picker.querySelectorAll<HTMLButtonElement>("[data-hero-picker-dot]"));
      const prev = picker.querySelector<HTMLButtonElement>("[data-hero-picker-prev]");
      const next = picker.querySelector<HTMLButtonElement>("[data-hero-picker-next]");
      let active = 0;

      const wrap = (value: number) => (value + cards.length) % cards.length;
      const positionFor = (index: number) => {
        if (index === active) return "active";
        if (index === wrap(active - 1)) return "left";
        if (index === wrap(active + 1)) return "right";
        return "hidden";
      };

      const render = () => {
        cards.forEach((card, index) => {
          const position = positionFor(index);
          card.dataset.pickerPosition = position;
          card.setAttribute("aria-hidden", position === "hidden" ? "true" : "false");
          const hit = card.querySelector<HTMLButtonElement>("[data-hero-picker-card-hit]");
          if (hit) hit.tabIndex = position === "active" || position === "hidden" ? -1 : 0;
          const play = card.querySelector<HTMLAnchorElement>(".hero-picker-play");
          if (play) play.tabIndex = position === "active" ? 0 : -1;
        });
        dots.forEach((dot, index) => {
          dot.setAttribute("aria-current", index === active ? "true" : "false");
        });
      };

      const select = (index: number) => {
        active = wrap(index);
        render();
      };

      prev?.addEventListener("click", () => select(active - 1));
      next?.addEventListener("click", () => select(active + 1));
      dots.forEach((dot) => {
        dot.addEventListener("click", () => select(Number(dot.dataset.pickerIndex ?? 0)));
      });

      picker.addEventListener("click", (event) => {
        const target = event.target as HTMLElement | null;
        const hit = target?.closest<HTMLElement>("[data-hero-picker-card-hit]");
        if (!hit) return;
        const card = hit.closest<HTMLElement>("[data-hero-picker-card]");
        if (!card) return;
        select(Number(card.dataset.pickerIndex ?? active));
      });

      picker.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          select(active - 1);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          select(active + 1);
        }
      });

      render();
    });
  }

  wireHeroGamePickers();
  document.addEventListener("astro:page-load", wireHeroGamePickers);
</script>

<style>
  .hero-picker-stage {
    box-shadow:
      inset 0 0 0 1px rgb(255 255 255 / 0.04),
      inset 0 -30px 60px rgb(0 0 0 / 0.38),
      0 34px 80px rgb(0 0 0 / 0.34);
  }

  .hero-picker-scanlines {
    background:
      repeating-linear-gradient(
        to bottom,
        rgb(255 255 255 / 0.055) 0,
        rgb(255 255 255 / 0.055) 1px,
        transparent 1px,
        transparent 7px
      );
    mix-blend-mode: soft-light;
    opacity: 0.45;
  }

  .hero-picker-card {
    transform-origin: center;
    transition:
      transform 380ms cubic-bezier(0.2, 0.78, 0.2, 1),
      opacity 260ms ease,
      filter 260ms ease;
  }

  .hero-picker-card[data-picker-position="active"] {
    z-index: 30;
    opacity: 1;
    transform: translateX(0) translateY(0) rotate(0deg) scale(1);
    filter: brightness(1) saturate(1);
  }

  .hero-picker-card[data-picker-position="left"] {
    z-index: 20;
    opacity: 0.88;
    transform: translateX(-82%) translateY(1.1rem) rotate(-8deg) scale(0.82);
    filter: brightness(0.55) saturate(0.82);
  }

  .hero-picker-card[data-picker-position="right"] {
    z-index: 20;
    opacity: 0.88;
    transform: translateX(82%) translateY(1.1rem) rotate(8deg) scale(0.82);
    filter: brightness(0.55) saturate(0.82);
  }

  .hero-picker-card[data-picker-position="hidden"] {
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transform: translateY(1.8rem) scale(0.74);
    filter: brightness(0.4);
  }

  .hero-picker-card[data-picker-position="left"]:hover,
  .hero-picker-card[data-picker-position="right"]:hover {
    filter: brightness(0.78) saturate(1);
  }

  .hero-picker-card-hit {
    cursor: pointer;
    background: transparent;
  }

  .hero-picker-card[data-picker-position="active"] .hero-picker-card-hit,
  .hero-picker-card[data-picker-position="hidden"] .hero-picker-card-hit {
    pointer-events: none;
  }

  .hero-picker-card:not([data-picker-position="active"]) .hero-picker-play {
    pointer-events: none;
    opacity: 0;
  }

  .hero-picker-play {
    animation: hero-picker-play-hop 1.35s cubic-bezier(0.45, 0, 0.2, 1) infinite;
  }

  .hero-picker-arrow {
    position: absolute;
    top: 50%;
    z-index: 60;
    display: grid;
    height: 3.2rem;
    width: 3.2rem;
    place-items: center;
    translate: 0 -50%;
    border: 2px solid rgb(255 255 255 / 0.22);
    background: rgb(6 6 16 / 0.82);
    color: #f8fafc;
    font-family: var(--font-display);
    font-size: 2.25rem;
    line-height: 1;
    box-shadow:
      4px 4px 0 rgb(0 0 0 / 0.55),
      0 0 18px rgb(34 211 238 / 0.16);
    transition:
      transform 140ms ease,
      border-color 140ms ease,
      color 140ms ease;
  }

  .hero-picker-arrow:hover {
    border-color: rgb(34 211 238 / 0.85);
    color: #67e8f9;
    transform: translateY(-2px);
  }

  .hero-picker-arrow:active {
    transform: translate(3px, 3px);
    box-shadow: 1px 1px 0 rgb(0 0 0 / 0.55);
  }

  .hero-picker-arrow--left {
    left: 0.65rem;
  }

  .hero-picker-arrow--right {
    right: 0.65rem;
  }

  .hero-picker-dot {
    height: 0.55rem;
    width: 1.4rem;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.08);
    transition:
      width 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .hero-picker-dot[aria-current="true"] {
    width: 2rem;
    border-color: rgb(34 211 238 / 0.7);
    background: #22d3ee;
    box-shadow: 0 0 12px rgb(34 211 238 / 0.5);
  }

  @keyframes hero-picker-play-hop {
    0%,
    100% {
      transform: translateY(0);
    }
    42% {
      transform: translateY(-7px);
    }
    58% {
      transform: translateY(-4px);
    }
  }

  @media (max-width: 640px) {
    .hero-picker-stage {
      padding-inline: 2.8rem;
    }

    .hero-picker-card[data-picker-position="left"] {
      transform: translateX(-86%) translateY(0.9rem) rotate(-8deg) scale(0.82);
    }

    .hero-picker-card[data-picker-position="right"] {
      transform: translateX(86%) translateY(0.9rem) rotate(8deg) scale(0.82);
    }

    .hero-picker-arrow {
      height: 2.7rem;
      width: 2.7rem;
      font-size: 1.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-picker-card,
    .hero-picker-arrow,
    .hero-picker-dot {
      transition: none;
    }

    .hero-picker-play {
      animation: none;
    }
  }
</style>
