---
import clsx from "clsx";
type Props = {
  class?: string;
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  aria-label="TeamBuild Games logo"
  viewBox="0 0 32 32"
  class={clsx("h-4 w-4 fill-cyan-400", Astro.props.class)}
  {...Astro.props}
>
  {/* Pixel gamepad: body with the d-pad and buttons punched out (even-odd). */}
  <path
    fill-rule="evenodd"
    d="M2 9h28v14H2zM7 12h4v2h2v4h-2v2H7v-2H5v-4h2zM19 15h4v4h-4zM24 11h4v4h-4z"
  ></path>
</svg>
