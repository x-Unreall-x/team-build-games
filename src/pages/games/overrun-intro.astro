---
import Layout from "../../components/layout/layout.astro";
import Footer from "../../components/layout/footer.astro";
import OverrunComicPreview from "../../components/game/overrun/OverrunComicPreview.tsx";
---

<Layout
  title="Overrun — intro comic (preview)"
  description="Preview of the Overrun campaign intro comic."
>
  <div class="mx-auto w-full max-w-4xl px-4 py-10">
    <a href="/games/overrun" class="font-display text-[9px] text-neutral-500 hover:text-cyan-300">
      &lt; Back to Overrun
    </a>
    <p class="eyebrow mt-6 text-red-400">Campaign intro</p>
    <h1 class="mt-3 font-display text-2xl text-white sm:text-3xl">Intro comic</h1>
    <p class="mt-3 text-sm text-neutral-400">
      5 panels · 2s each · the squad prepares, deploys, and approaches the science lab.
    </p>
    <div class="mt-8">
      <OverrunComicPreview client:only="react" />
    </div>
  </div>
  <Footer />
</Layout>
