---
import Footer from "../../components/layout/footer.astro";
import Layout from "../../components/layout/layout.astro";
import Arena from "../../components/game/Arena.tsx";
---

<Layout>
  <div class="mx-auto w-full max-w-4xl px-4 py-10">
    <div class="mb-6">
      <a href="/" class="text-sm text-neutral-500 hover:underline">← Game pack</a>
      <h1 class="mt-2 text-4xl font-bold">Arena</h1>
      <p class="mt-1 text-neutral-500 dark:text-neutral-400">
        Last musa standing — dash, swing, and survive on a 30 m field.
      </p>
    </div>

    <Arena client:only="react" />
  </div>
  <Footer />
</Layout>
