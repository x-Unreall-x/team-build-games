---
import Footer from "../components/layout/footer.astro";
import Layout from "../components/layout/layout.astro";
import GameSwitcher from "../components/games/GameSwitcher.astro";
import { getSessionMember } from "../lib/wix/members";

// SSR: the form is member-only — pitches carry a name so ideas can be credited.
const member = await getSessionMember();

const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error");
const ERROR_COPY: Record<string, string> = {
  auth: "Your session expired mid-pitch — sign in and try again.",
  input: "Give the game a name (3+ characters) and a real pitch (10+ characters).",
  save: "Couldn't save your pitch — try again in a minute.",
};
const errorMessage = error ? (ERROR_COPY[error] ?? ERROR_COPY.save) : null;
---

<Layout
  title="Pitch a game — TeamBuild Games"
  description="The empty cabinet is waiting: pitch the next game for your team's arcade."
>
  <div class="mx-auto w-full max-w-2xl px-4 py-16">
    <a
      href="/#games"
      class="font-display text-[9px] text-neutral-500 hover:text-amber-300"
    >
      &lt; Back to the arcade
    </a>
    <p class="eyebrow mt-6 text-amber-300">The empty cabinet</p>
    <h1 class="mt-3 font-display text-2xl text-white sm:text-3xl">
      Pitch a game
    </h1>
    <p class="mt-4 leading-relaxed text-neutral-400">
      The <span class="font-display text-[10px] text-amber-300">???</span>
      cabinet is reserved for your team's idea. Pitch the next game — the best
      ones get built into the pack.
    </p>

    {
      errorMessage && !sent && (
        <p class="mt-8 rounded-lg border border-red-400/40 bg-red-500/10 px-4 py-3 text-sm text-red-300">
          {errorMessage}
        </p>
      )
    }

    {
      sent ? (
        <div class="pixel-grid mt-10 rounded-2xl border border-emerald-400/40 bg-night-900 px-6 py-12 text-center shadow-[0_0_48px_rgb(52_211_153/0.15)]">
          <p class="neon font-display text-lg text-emerald-400">
            * Pitch received *
          </p>
          <p class="mx-auto mt-5 max-w-md text-neutral-400">
            Your idea is in the queue with your name on it. Watch the cabinet
            floor — and start lobbying your teammates.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href="/suggest" class="arcade-btn arcade-btn-ghost">
              Pitch another
            </a>
            <a href="/games/arena" class="arcade-btn">
              ▶ Back to playing
            </a>
          </div>
        </div>
      ) : member ? (
        <form method="POST" action="/api/suggest-game" class="mt-10">
          <div class="rounded-2xl border border-amber-300/30 bg-night-900 p-6">
            <label class="block">
              <span class="font-display text-[9px] text-neutral-400">
                Game name
              </span>
              <input
                type="text"
                name="title"
                required
                minlength={3}
                maxlength={80}
                placeholder="e.g. Standup Kart"
                class="mt-2 w-full rounded-lg border border-white/15 bg-night-950 px-4 py-3 text-neutral-100 placeholder:text-neutral-600"
              />
            </label>
            <label class="mt-6 block">
              <span class="font-display text-[9px] text-neutral-400">
                The pitch
              </span>
              <textarea
                name="pitch"
                required
                minlength={10}
                maxlength={1000}
                rows={6}
                placeholder="What do we play, how do we win, and why will the team love it?"
                class="mt-2 w-full rounded-lg border border-white/15 bg-night-950 px-4 py-3 leading-relaxed text-neutral-100 placeholder:text-neutral-600"
              />
            </label>
            <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
              <span class="text-xs text-neutral-500">
                Pitching as
                <span class="text-neutral-300">{member.name}</span> — the
                credit (and the blame) is yours.
              </span>
              <button type="submit" class="arcade-btn">
                ▶ Submit pitch
              </button>
            </div>
          </div>
        </form>
      ) : (
        <div class="mt-10 rounded-2xl border border-white/10 bg-night-900 px-6 py-12 text-center">
          <p class="font-display text-xs text-neutral-300">🔒 Members only</p>
          <p class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-neutral-400">
            Sign in to pitch your game — pitches carry your name, so the credit
            lands on you when it ships. Playing stays anonymous either way.
          </p>
          <div class="mt-8 flex justify-center">
            <a
              href="/api/auth/login?returnToUrl=/suggest"
              data-astro-reload
              data-astro-prefetch="false"
              class="arcade-btn"
            >
              ▶ Sign in to pitch
            </a>
          </div>
        </div>
      )
    }

    <div class="mt-12">
      <GameSwitcher slug="mystery" />
    </div>
  </div>
  <Footer />
</Layout>
