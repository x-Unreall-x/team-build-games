---
import Footer from "../components/layout/footer.astro";
import RootLayout from "../components/layout/layout.astro";
import { getSessionMember } from "../lib/wix/members";

// SSR: reflect login state in the header button (per request).
const member = await getSessionMember();
const LOGIN_HINT =
  "Sign in to use a custom character photo and save your progress across games. You can still play anonymously — signing in just unlocks the extras.";

interface GamePackEntry {
  slug: string;
  name: string;
  kind: string;
  blurb: string;
  href: string | null;
  status: "play" | "soon";
  accent: string;
}

const games: GamePackEntry[] = [
  {
    slug: "arena",
    name: "Arena",
    kind: "Realtime",
    blurb:
      "Run around a 30 m field and meet the shop-keeper. Multiplayer (P2P) coming in a later build.",
    href: "/games/arena",
    status: "play",
    accent: "from-sky-500/20 to-emerald-500/20",
  },
  {
    slug: "tactics",
    name: "Tactics",
    kind: "Turn-based",
    blurb: "A turn-based game. Not built yet — stay tuned.",
    href: null,
    status: "soon",
    accent: "from-fuchsia-500/15 to-amber-500/15",
  },
];
---

<RootLayout>
  <section class="mx-auto w-full max-w-5xl px-4 py-12">
    <header class="mb-10 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-5xl font-bold tracking-tight">TeamBuild Games</h1>
        <p class="mt-3 max-w-2xl text-lg text-neutral-500 dark:text-neutral-400">
          A pack of small multiplayer games, backed by Wix Headless. Pick one to play.
        </p>
      </div>
      {
        member ? (
          <a
            href="/account"
            title="View your account"
            class="flex shrink-0 items-center gap-2 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-medium hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-800"
          >
            {member.avatarUrl ? (
              <img src={member.avatarUrl} alt="" class="h-6 w-6 rounded-full object-cover" />
            ) : (
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-neutral-200 text-xs dark:bg-neutral-700">
                🙂
              </span>
            )}
            <span class="max-w-[11rem] truncate">{member.email ?? member.name}</span>
          </a>
        ) : (
          <a
            href="/api/auth/login?returnUrl=/"
            title={LOGIN_HINT}
            class="shrink-0 rounded-lg border border-neutral-300 px-4 py-2 text-sm font-medium hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-800"
          >
            Log-in
          </a>
        )
      }
    </header>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        games.map((game) => {
          const card = (
            <div
              class={`group relative flex h-full flex-col rounded-2xl border border-neutral-200 bg-gradient-to-br p-6 transition dark:border-neutral-800 ${game.accent} ${
                game.status === "play"
                  ? "hover:-translate-y-1 hover:shadow-lg"
                  : "opacity-60"
              }`}
            >
              <div class="mb-3 flex items-center gap-2">
                <span class="rounded-full bg-black/10 px-3 py-1 text-xs font-medium uppercase tracking-wide dark:bg-white/10">
                  {game.kind}
                </span>
                {game.status === "soon" && (
                  <span class="rounded-full bg-amber-500/20 px-3 py-1 text-xs font-medium text-amber-700 dark:text-amber-300">
                    Coming soon
                  </span>
                )}
              </div>
              <h2 class="text-2xl font-semibold">{game.name}</h2>
              <p class="mt-2 flex-1 text-neutral-600 dark:text-neutral-300">{game.blurb}</p>
              <span
                class={`mt-5 inline-flex w-fit items-center gap-1 text-sm font-medium ${
                  game.status === "play"
                    ? "text-sky-700 group-hover:gap-2 dark:text-sky-300"
                    : "text-neutral-400"
                }`}
              >
                {game.status === "play" ? "Play →" : "Locked"}
              </span>
            </div>
          );

          return game.href ? (
            <a href={game.href} class="block h-full no-underline">
              {card}
            </a>
          ) : (
            <div aria-disabled="true">{card}</div>
          );
        })
      }
    </div>
  </section>
  <Footer />
</RootLayout>
