---
import Footer from "../components/layout/footer.astro";
import RootLayout from "../components/layout/layout.astro";
import { getSessionMember } from "../lib/wix/members";

// SSR: read the current member (currently anonymous until @wix/members + Members Area app land).
const member = await getSessionMember();
---

<RootLayout>
  <section class="mx-auto w-full max-w-2xl px-4 py-12">
    <h1 class="text-4xl font-bold tracking-tight">Account</h1>

    {
      member ? (
        <div class="mt-6 flex flex-col gap-5">
          <div class="flex items-center gap-4">
            {member.avatarUrl ? (
              <img src={member.avatarUrl} alt="" class="h-16 w-16 rounded-full object-cover" />
            ) : (
              <div class="flex h-16 w-16 items-center justify-center rounded-full bg-neutral-200 text-2xl dark:bg-neutral-700">
                🙂
              </div>
            )}
            <div>
              <div class="text-lg font-semibold">{member.name}</div>
              <div class="text-sm text-neutral-500">Signed in</div>
            </div>
          </div>
          <form method="POST" action="/api/auth/logout?returnUrl=/account">
            <button
              type="submit"
              class="rounded-lg border border-neutral-300 px-4 py-2 text-sm font-medium hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-800"
            >
              Sign out
            </button>
          </form>
          <p class="text-sm text-neutral-500">
            Custom avatar upload (B1) and saved progress (B2) are coming next.
          </p>
        </div>
      ) : (
        <div class="mt-6 flex flex-col items-start gap-4">
          <p class="max-w-prose text-neutral-600 dark:text-neutral-300">
            Sign in to use a custom character photo and save your progress across games. You can
            still play anonymously — signing in just unlocks the extras.
          </p>
          <a
            href="/api/auth/login?returnUrl=/account"
            class="rounded-lg bg-sky-500 px-5 py-2 font-semibold text-white hover:bg-sky-400"
          >
            Sign in
          </a>
        </div>
      )
    }
  </section>
  <Footer />
</RootLayout>
