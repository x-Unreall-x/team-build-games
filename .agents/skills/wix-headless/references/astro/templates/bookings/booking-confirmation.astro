---
// src/pages/booking-confirmation.astro — post-booking confirmation.
//
// Renders from the redirect query params (service name + start date) that the
// booking step passes through. The Wix-hosted checkout returns here after a paid
// booking; a free / pay-in-person booking lands here directly. Do not re-fetch a
// stranger's booking from this public page — show what the flow passed in.
import Layout from "../layouts/Layout.astro";

const serviceName = Astro.url.searchParams.get("service") ?? "your service";
const startDateParam = Astro.url.searchParams.get("startDate");
const formattedDate = startDateParam
  ? new Date(startDateParam).toLocaleString("en-US", {
      weekday: "long", month: "long", day: "numeric", hour: "2-digit", minute: "2-digit",
    })
  : null;
---

<!-- `max-w-prose` (built-in literal = 65ch), not a bare max-w-<size> that could
     collapse to the spacing scale. -->
<Layout title="Booking confirmed">
  <section class="max-w-prose mx-auto px-lg py-4xl text-center">
    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-xl"
         style="background-color: var(--color-accent);" aria-hidden="true">
      <span class="text-2xl" style="color: var(--color-paper);">✓</span>
    </div>
    <hr class="editorial-rule w-16 mx-auto mb-lg" />
    <h1 class="font-display text-4xl md:text-5xl leading-tight mb-md">Thank you for booking</h1>

    {
      formattedDate ? (
        <p class="text-lg text-mute leading-relaxed mb-md">
          Your spot in <strong class="text-ink">{serviceName}</strong> is <strong class="text-ink">confirmed</strong> for{" "}
          <strong class="text-ink">{formattedDate}</strong>. We've sent the details to your email.
        </p>
      ) : (
        <p class="text-lg text-mute leading-relaxed mb-md">
          Your booking for <strong class="text-ink">{serviceName}</strong> is <strong class="text-ink">confirmed</strong>. We've sent the details to your email.
        </p>
      )
    }

    <div class="flex flex-col gap-md items-center">
      <a href="/services" class="inline-block font-display text-base px-xl py-md rounded-sm"
         style="background-color: var(--color-accent); color: var(--color-paper);">Browse more services</a>
      <a href="/" class="text-sm text-mute hover:text-ink">Return home</a>
    </div>
  </section>
</Layout>
