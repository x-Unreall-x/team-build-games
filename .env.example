# Wix client credentials — pull with `wix env pull` (do not commit real values).
WIX_CLIENT_ID=
WIX_CLIENT_SECRET=

# ── WebRTC TURN relay (Arena P2P) ────────────────────────────────────────────
# STUN alone can't connect two devices behind the same home NAT. A TURN relay is
# required for reliable cross-device play. Creds are client-visible by design
# (they ship in the browser bundle), so PUBLIC_* is correct here.
#
# Get free creds in ~2 min at https://dashboard.metered.ca (Open Relay, 50GB/mo),
# or use any TURN provider / self-hosted coturn.
#
# For the DEPLOYED site these must exist at BUILD time — set them with:
#   wix env set --key PUBLIC_TURN_URLS       --value "turn:...:80,turns:...:443"
#   wix env set --key PUBLIC_TURN_USERNAME   --value "<username>"
#   wix env set --key PUBLIC_TURN_CREDENTIAL --value "<credential>"
# then redeploy (`wix release -c "add TURN"`). For local play, set them in .env.local.
#
# Comma-separate multiple TURN URLs (80 for UDP/TCP, 443/turns for TLS through firewalls).
PUBLIC_TURN_URLS=
PUBLIC_TURN_USERNAME=
PUBLIC_TURN_CREDENTIAL=

# Optional: override the default STUN server(s) (comma-separated). Defaults to Google STUN.
# PUBLIC_STUN_URLS=stun:stun.l.google.com:19302
